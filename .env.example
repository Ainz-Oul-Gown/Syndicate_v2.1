# Client-side variables. Values prefixed with VITE_ are embedded into the browser bundle.
# Never put service-role keys, bot tokens, SMTP passwords, or JWT secrets in VITE_ variables.

# Supabase client configuration
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Firebase Web configuration used only for Google sign-in
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN="YOUR_PROJECT.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_FIREBASE_STORAGE_BUCKET="YOUR_PROJECT.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# Server-side variables for Supabase Edge Functions / Telegram bot.
# Configure these with `supabase secrets set` or in the server environment.
# Never expose them through GitHub Pages or prefix them with VITE_.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
JWT_SECRET=""
TELEGRAM_BOT_TOKEN=""
TELEGRAM_OTP_SECRET=""
TELEGRAM_INIT_DATA_MAX_AGE_SECONDS="900"
# Exactly 32 random bytes encoded as base64
PROVIDER_VAULT_MASTER_KEY=""

# Supabase Edge Function secret (set with `supabase secrets set`, never VITE_*)
# FIREBASE_API_KEY=your_firebase_web_api_key
